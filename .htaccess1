# Aktifkan Rewrite Engine
RewriteEngine On
RewriteBase /

# Keamanan: Sembunyikan versi PHP & Server
ServerSignature Off
Header unset X-Powered-By

# Keamanan: Blokir akses file sensitif
<FilesMatch "(^\.|\.(sql|md|ini|log|sh|inc|bak|swp)$|config\.php)">
    Order allow,deny
    Deny from all
</FilesMatch>

# Keamanan: Blokir akses langsung ke folder includes & admin/includes
RewriteRule ^(includes|admin/includes)/ - [F,L]

# Keamanan: Blokir akses ke folder upload kalau ada file .php
<FilesMatch "\.php$">
    SetHandler application/x-httpd-php
</FilesMatch>
<DirectoryMatch "^.*/assets/img/">
    <FilesMatch "\.php$">
        Deny from all
    </FilesMatch>
</DirectoryMatch>

# URL Cantik untuk Frontend - Hilangkan .php
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^\.]+)$ $1.php [NC,L]

# Redirect www ke non-www atau sebaliknya, pilih salah satu
# RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
# RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# Force HTTPS - aktifkan kalau sudah SSL
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Cegah directory listing
Options -Indexes

# Compress file untuk loading lebih cepat
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/javascript
</IfModule>

# Cache browser untuk assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>